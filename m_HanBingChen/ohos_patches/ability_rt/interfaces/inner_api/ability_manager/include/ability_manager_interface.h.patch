    /**
     * Start an Ability within an existing Mission (push onto Ability stack).
     * Used by Android adapter to add a new Activity to the same Task/Mission.
     *
     * For OH native apps, use StartAbility() which creates a new Mission.
     * For Android adapted apps, use this method to push Activities onto
     * an existing Mission's Ability stack.
     *
     * @param want       the Want to start the new Ability
     * @param missionId  the target Mission ID to push the Ability into
     * @return ERR_OK on success
     */
    virtual int StartAbilityInMission(const Want &want, int32_t missionId) = 0;

