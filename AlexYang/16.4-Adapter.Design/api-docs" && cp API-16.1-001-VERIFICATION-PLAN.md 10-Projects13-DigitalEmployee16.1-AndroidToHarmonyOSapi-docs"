## 📚 API 参考

### IAppCompatActivity 接口

#### 生命周期方法

```typescript
interface IAppCompatActivity {
  /**
   * 初始化活动/页面
   * 映射到: Android onCreate() + onResume()
   *        HarmonyOS onPageShow()
   */
  init(): void;

  /**
   * 活动/页面显示
   * 映射到: Android onResume()
   *        HarmonyOS onPageShow()
   */
  onShow(): void;

  /**
   * 活动/页面隐藏
   * 映射到: Android onPause()
   *        HarmonyOS onPageHide()
   */
  onHide(): void;

  /**
   * 销毁活动/页面
   * 映射到: Android onDestroy()
   */
  destroy(): void;
}
```

#### UI 操作方法

```typescript
/**
 * 设置内容视图 (仅 Android)
 * @param layoutId 布局资源 ID
 */
setContentView(layoutId: string): void;

/**
 * 查找 UI 组件
 * @param id 组件 ID
 * @returns 包装的组件或 null
 */
findViewById(id: string): ComponentWrapper | null;

/**
 * 设置点击监听
 * @param viewId 组件 ID
 * @param callback 回调函数
 */
setOnClickListener(viewId: string, callback: Function): void;
```

#### 状态管理方法

```typescript
/**
 * 保存状态
 * @param state 要保存的状态对象
 */
saveState(state: any): void;

/**
 * 恢复状态
 * @returns 恢复的状态对象
 */
restoreState(): any;
```

#### 数据访问方法

```typescript
/**
 * 获取位置字符串
 * @returns 位置文本
 */
getLocation(): string;

/**
 * 设置位置字符串
 * @param location 新的位置文本
 */
setLocation(location: string): void;

/**
 * 获取时间字符串
 * @returns 时间文本
 */
getTime(): string;

/**
 * 检查是否在更新
 * @returns true 如果正在更新
 */
isUpdating(): boolean;

/**
 * 更新 UI
 */
updateUI(): void;
```

