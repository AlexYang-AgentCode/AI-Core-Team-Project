/**
 * Android Activity Base Class
 * 
 * Maps HarmonyOS UIAbility lifecycle to Android Activity lifecycle.
 * This class is the foundation for all Android Activity compatibility.
 */

import { UIAbility, Want, AbilityConstant } from '@kit.AbilityKit';
import { window } from '@kit.ArkUI';
import { hilog } from '@kit.PerformanceAnalysisKit';
import { Bundle } from '../os/Bundle';
import { ActivityState, LifecycleStateMachine } from '../lifecycle/LifecycleState';
import { viewFinder } from '../view/ViewFinder';
import { layoutInflater } from '../view/LayoutInflater';
import { Context } from '../content/Context';
import { Intent } from '../content/Intent';

const TAG = 'Activity';

export abstract class Activity extends UIAbility {
  // Lifecycle state machine
  private _lifecycleState: LifecycleStateMachine = new LifecycleStateMachine();
  
  // Android-compatible state flags
  private _isCreated: boolean = false;
  private _isStarted: boolean = false;
  private _isResumed: boolean = false;
  
  // Window stage reference
  private _windowStage: window.WindowStage | null = null;
  
  // Pending layout for setContentView
  private _pendingLayoutId: number | null = null;
  
  // Saved instance state
  private _savedInstanceState: Bundle | null = null;
  
  // Context wrapper
  private _context: Context | null = null;

  /**
   * Android-compatible lifecycle callbacks
   * Subclasses (generated by JIT) override these methods
   */
  
  /**
   * Called when the activity is starting.
   * This is where most initialization should go.
   */
  protected onCreate(savedInstanceState: Bundle | null): void {
    hilog.debug(0x0000, TAG, 'onCreate called');
  }

  /**
   * Called after onCreate — or after onRestart when the activity had been stopped.
   */
  protected onStart(): void {
    hilog.debug(0x0000, TAG, 'onStart called');
  }

  /**
   * Called after onRestoreInstanceState, onRestart, or onPause.
   * The activity is now visible and ready for user interaction.
   */
  protected onResume(): void {
    hilog.debug(0x0000, TAG, 'onResume called');
  }

  /**
   * Called as part of the activity lifecycle when an activity is going into the background.
   */
  protected onPause(): void {
    hilog.debug(0x0000, TAG, 'onPause called');
  }

  /**
   * Called when you are no longer visible to the user.
   */
  protected onStop(): void {
    hilog.debug(0x0000, TAG, 'onStop called');
  }

  /**
   * Perform any final cleanup before an activity is destroyed.
   */
  protected onDestroy(): void {
    hilog.debug(0x0000, TAG, 'onDestroy called');
  }

  /**
   * Called to retrieve per-instance state from an activity before being killed.
   */
  protected onSaveInstanceState(outState: Bundle): void {
    hilog.debug(0x0000, TAG, 'onSaveInstanceState called');
  }

  /**
   * This method is called after onStart when the activity is being re-initialized.
   */
  protected onRestoreInstanceState(savedInstanceState: Bundle): void {
    hilog.debug(0x0000, TAG, 'onRestoreInstanceState called');
  }

  /**
   * Called after onStop when the current activity is being re-displayed to the user.
   */
  protected onRestart(): void {
    hilog.debug(0x0000, TAG, 'onRestart called');
  }

  /**
   * Android-compatible methods
   */
  
  /**
   * Set the activity content from a layout resource.
   * @param layoutResID Resource ID to be inflated
   */
  setContentView(layoutResID: number): void {
    hilog.info(0x0000, TAG, `setContentView called with layout: 0x${layoutResID.toString(16)}`);
    
    if (this._windowStage) {
      // Window stage already created, inflate immediately
      this._inflateLayout(layoutResID);
    } else {
      // Buffer the layout request for later
      this._pendingLayoutId = layoutResID;
    }
  }

  /**
   * Finds a view that was identified by the android:id XML attribute.
   * @param id The ID to search for
   * @returns The view if found, or null
   */
  findViewById<T>(id: number): T | null {
    return viewFinder.findViewById<T>(id);
  }

  /**
   * Returns the application context.
   */
  getApplicationContext(): Context {
    if (!this._context) {
      this._context = new Context(this.context);
    }
    return this._context.getApplicationContext();
  }

  /**
   * Returns the context of this Activity.
   */
  getContext(): Context {
    if (!this._context) {
      this._context = new Context(this.context);
    }
    return this._context;
  }

  /**
   * Finish this activity.
   */
  finish(): void {
    hilog.info(0x0000, TAG, 'finish called');
    this.context.terminateSelf();
  }

  /**
   * Retrieve the intent that started this activity.
   */
  getIntent(): Intent {
    // Create Intent from Want
    return Intent.fromWant(this.launchWant);
  }

  /**
   * Check if this activity is finishing.
   */
  isFinishing(): boolean {
    return this._lifecycleState.getState() === ActivityState.DESTROYED;
  }

  /**
   * HarmonyOS UIAbility lifecycle mapping
   * DO NOT OVERRIDE - Internal implementation
   */
  
  onCreate(want: Want, launchParam: AbilityConstant.LaunchParam): void {
    super.onCreate(want, launchParam);
    hilog.info(0x0000, TAG, 'HarmonyOS onCreate');
    
    // Convert Want to Bundle
    this._savedInstanceState = Bundle.fromWant(want);
    
    // Transition to CREATED state
    this._lifecycleState.transitionTo(ActivityState.CREATED);
    
    // Call Android onCreate
    this.onCreate(this._savedInstanceState);
    this._isCreated = true;
  }

  onWindowStageCreate(windowStage: window.WindowStage): void {
    super.onWindowStageCreate(windowStage);
    hilog.info(0x0000, TAG, 'HarmonyOS onWindowStageCreate');
    
    this._windowStage = windowStage;
    
    // Apply pending layout if set
    if (this._pendingLayoutId !== null) {
      this._inflateLayout(this._pendingLayoutId);
    }
  }

  onWindowStageDestroy(): void {
    super.onWindowStageDestroy();
    hilog.info(0x0000, TAG, 'HarmonyOS onWindowStageDestroy');
    
    // Trigger Android lifecycle callbacks
    if (this._isResumed) {
      this.onPause();
      this._isResumed = false;
    }
    if (this._isStarted) {
      this.onStop();
      this._isStarted = false;
    }
  }

  onForeground(): void {
    super.onForeground();
    hilog.info(0x0000, TAG, 'HarmonyOS onForeground');
    
    if (!this._isStarted) {
      this._lifecycleState.transitionTo(ActivityState.STARTED);
      this.onStart();
      this._isStarted = true;
    }
    
    if (!this._isResumed) {
      this._lifecycleState.transitionTo(ActivityState.RESUMED);
      this.onResume();
      this._isResumed = true;
    }
  }

  onBackground(): void {
    super.onBackground();
    hilog.info(0x0000, TAG, 'HarmonyOS onBackground');
    
    if (this._isResumed) {
      this._lifecycleState.transitionTo(ActivityState.PAUSED);
      this.onPause();
      this._isResumed = false;
    }
    
    if (this._isStarted) {
      this._lifecycleState.transitionTo(ActivityState.STOPPED);
      this.onStop();
      this._isStarted = false;
    }
  }

  onDestroy(): void {
    super.onDestroy();
    hilog.info(0x0000, TAG, 'HarmonyOS onDestroy');
    
    // Save instance state if needed
    if (this._lifecycleState.getState() !== ActivityState.DESTROYED) {
      const outState = new Bundle();
      this.onSaveInstanceState(outState);
    }
    
    // Transition to destroyed
    this._lifecycleState.transitionTo(ActivityState.DESTROYED);
    this.onDestroy();
    
    // Cleanup
    this._isCreated = false;
    viewFinder.clear();
  }

  /**
   * Private helper methods
   */
  
  private async _inflateLayout(layoutId: number): Promise<void> {
    if (!this._windowStage) {
      hilog.error(0x0000, TAG, 'WindowStage not available');
      return;
    }
    
    try {
      await layoutInflater.inflate(layoutId, this._windowStage);
      
      // Trigger lifecycle after layout loaded
      if (!this._isStarted) {
        this.onStart();
        this._isStarted = true;
      }
      if (!this._isResumed) {
        this.onResume();
        this._isResumed = true;
      }
    } catch (err) {
      hilog.error(0x0000, TAG, `Failed to inflate layout: ${JSON.stringify(err)}`);
    }
  }
}
