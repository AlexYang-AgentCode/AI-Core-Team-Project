## 🔧 **核心组件设计**

### 1. AppCompatActivity (Android)

**职责**:
- 容器管理
- 生命周期管理
- UI 加载和初始化
- 事件处理

**关键方法**:
```java
public class MainActivity extends AppCompatActivity {
    // 成员变量 (持有所有 UI 组件)
    private TextClock textClock;
    private Button refreshButton;
    private TextView locationView;

    // 生命周期方法
    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);  // 加载布局
        initializeViews();                        // 初始化组件
        setupListeners();                         // 设置监听器
    }

    @Override
    protected void onResume() {
        super.onResume();
        startUpdates();  // 启动更新
    }

    @Override
    protected void onPause() {
        super.onPause();
        stopUpdates();   // 停止更新
    }

    // 初始化视图
    private void initializeViews() {
        textClock = findViewById(R.id.text_clock);
        refreshButton = findViewById(R.id.refresh_button);
        locationView = findViewById(R.id.location_text);
    }

    // 设置事件监听
    private void setupListeners() {
        refreshButton.setOnClickListener(v -> onRefreshClicked());
    }

    // 事件处理
    private void onRefreshClicked() {
        // 刷新逻辑
    }

    private void startUpdates() {
        // 启动 TextClock 更新
    }

    private void stopUpdates() {
        // 停止 TextClock 更新
    }
}
```

### 2. MainPage (HarmonyOS)

**职责**:
- 页面管理
- 状态管理 (@State)
- UI 构建 (build())
- 事件处理

**关键方法**:
```typescript
@Entry
@Component
struct MainPage {
    @State textClockValue: string = '';
    @State locationText: string = '';
    @State isRunning: boolean = false;

    // UI 构建
    build() {
        Column() {
            Text(this.textClockValue)
                .fontSize(48)
                .margin(20)

            Button('Refresh')
                .onClick(() => this.onRefreshClicked())
                .margin(20)

            Text(this.locationText)
                .fontSize(14)
                .margin(20)
        }
        .padding(20)
    }

    // 页面生命周期
    onPageShow() {
        // 对应 Android onCreate + onResume
        this.initializeData();
        this.startUpdates();
        this.isRunning = true;
    }

    onPageHide() {
        // 对应 Android onPause
        this.stopUpdates();
        this.isRunning = false;
    }

    // 初始化数据
    private initializeData() {
        this.updateTime();
        this.updateLocation();
    }

    // 事件处理
    private onRefreshClicked() {
        this.updateTime();
        this.updateLocation();
    }

    // 定时更新
    private startUpdates() {
        // 启动定时器更新时间
    }

    private stopUpdates() {
        // 停止定时器
    }

    private updateTime() {
        // 更新时间显示
        this.textClockValue = new Date().toLocaleTimeString();
    }

    private updateLocation() {
        // 更新位置显示
        this.locationText = '位置信息';
    }
}
```

### 3. AppCompatActivityAdapter (统一接口)

**职责**:
- 统一 Android 和 HarmonyOS 的接口
- 屏蔽平台差异
- 提供通用 API

**接口设计**:
```typescript
interface IAppCompatActivity {
    // 初始化
    init(): void;

    // 生命周期
    onShow(): void;
    onHide(): void;

    // UI 操作
    setContentView(layoutId: string): void;
    findViewById(id: string): any;

    // 事件监听
    setOnClickListener(viewId: string, callback: Function): void;

    // 数据管理
    saveState(state: any): void;
    restoreState(): any;

    // 生命周期控制
    start(): void;
    stop(): void;
    pause(): void;
    resume(): void;
}

// 实现
class AppCompatActivityAdapter implements IAppCompatActivity {
    private activity: any;

    constructor(activity: MainActivity | MainPage) {
        this.activity = activity;
    }

    init(): void {
        if (this.isAndroid()) {
            this.activity.onCreate(null);
        } else {
            this.activity.onPageShow();
        }
    }

    onShow(): void {
        if (this.isAndroid()) {
            this.activity.onResume();
        } else {
            this.activity.onPageShow();
        }
    }

    onHide(): void {
        if (this.isAndroid()) {
            this.activity.onPause();
        } else {
            this.activity.onPageHide();
        }
    }

    setContentView(layoutId: string): void {
        if (this.isAndroid()) {
            this.activity.setContentView(layoutId);
        } else {
            // HarmonyOS: 在 build() 中定义
        }
    }

    // ... 其他方法
}
```

