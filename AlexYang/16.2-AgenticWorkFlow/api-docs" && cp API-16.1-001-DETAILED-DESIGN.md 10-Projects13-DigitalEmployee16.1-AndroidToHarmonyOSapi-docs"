## 🔌 **接口设计**

### 公开接口

```typescript
// 初始化接口
interface IActivityInitializer {
    initialize(): void;
    destroy(): void;
}

// 生命周期接口
interface IActivityLifecycle {
    onCreate(): void;
    onStart(): void;
    onResume(): void;
    onPause(): void;
    onStop(): void;
    onDestroy(): void;
}

// UI 操作接口
interface IUIOperation {
    findViewById(id: string): View;
    setContentView(layoutId: string): void;
    setClickListener(viewId: string, listener: OnClickListener): void;
}

// 完整接口
interface IAppCompatActivity extends IActivityInitializer, IActivityLifecycle, IUIOperation {
    // 组合所有接口
}
