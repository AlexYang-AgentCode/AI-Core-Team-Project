#### HarmonyOS 映射布局
```typescript
@Entry
@Component
struct MainPage {
    @State textClockValue: string = '';
    @State locationText: string = '';

    build() {
        Column({ space: 20 }) {
            // 映射: TextClock → Text
            Text(this.textClockValue)
                .fontSize(48)
                .fontColor(Color.Black)

            // 映射: Button → Button
            Button('Refresh')
                .onClick(() => this.onRefreshClicked())

            // 映射: TextView → Text
            Text(this.locationText)
                .fontSize(14)
                .fontColor(Color.Gray)
        }
        .padding(20)
        .justifyContent(FlexAlign.Start)
    }

    // 更新函数
    private updateTextClock() {
        // 映射: TextClock 组件 → @State 变量
        this.textClockValue = new Date().toLocaleTimeString();
    }

    private updateLocation() {
        // 映射: TextView setText → @State 赋值
        this.locationText = '当前位置信息';
    }
}
