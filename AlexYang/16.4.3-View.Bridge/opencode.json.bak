{
  "$schema": "https://opencode.ai/config.json",
    "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "external_directory": "allow",
    "lsp": "allow",
    "skill": "allow",
    "task": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow"
  },
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek Reasoner (V3.2)",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-reasoner": {
          "name": "DeepSeek Reasoner (V3.2)"
        }
      }
    }
  }
}
